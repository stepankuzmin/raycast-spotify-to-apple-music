{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "lib": [
      "ES2022"
    ],
    "moduleResolution": "nodenext",
    "types": [
      "node"
    ],
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
